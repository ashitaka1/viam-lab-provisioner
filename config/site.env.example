# =============================================================================
# Site Configuration
# =============================================================================
# Run `just setup-wizard` to create this file interactively,
# or copy to site.env and edit manually.

# --- Machine batch ---
# Hostname prefix and count for this provisioning run
PREFIX=lab-pi
COUNT=10

# --- OS account ---
# Username and password for the provisioned machines
USERNAME=viam
PASSWORD=checkmate

# --- Network ---
# WiFi credentials (leave both blank to skip WiFi configuration)
WIFI_SSID=
WIFI_PASSWORD=

# Timezone (IANA format)
TIMEZONE=America/New_York

# --- SSH ---
# Path to the SSH public key to authorize on provisioned machines.
# The setup wizard can generate a dedicated keypair and configure
# your SSH client so `ssh <prefix>-*` just works.
SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub

# --- Viam Cloud (optional) ---
# Provision mode controls what gets installed:
#   "full"     = create machines in Viam + install viam-agent + deploy credentials
#   "agent"    = install viam-agent binary (no credentials — user sets up Viam themselves)
#   "os-only"  = just configure the OS, no Viam software at all
PROVISION_MODE=os-only

# Required only when PROVISION_MODE=full:
VIAM_API_KEY_ID=
VIAM_API_KEY=
VIAM_ORG_ID=
VIAM_LOCATION_ID=

# --- Tailscale (optional) ---
# Leave blank to skip Tailscale installation entirely.
# Generate a key at: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=

# =============================================================================
# Environment Configuration
# =============================================================================
# Run `just setup-wizard` to create this interactively.
# Stores stable site/org settings. Per-run details (prefix, count) are
# passed as arguments to `just provision`.

# --- OS account ---
USERNAME=viam
PASSWORD=checkmate

# --- Network ---
# WiFi credentials (leave both blank to skip WiFi)
WIFI_SSID=
WIFI_PASSWORD=

# Timezone (IANA format)
TIMEZONE=America/New_York

# --- SSH ---
# Path to the SSH public key to authorize on provisioned machines
SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub

# --- Viam Cloud (optional) ---
# Provision mode controls what gets installed:
#   "full"     = create machines in Viam + install viam-agent + deploy credentials
#   "agent"    = install viam-agent binary (no credentials — user sets up Viam)
#   "os-only"  = just configure the OS, no Viam software at all
PROVISION_MODE=os-only

# Required only when PROVISION_MODE=full:
VIAM_API_KEY_ID=
VIAM_API_KEY=
VIAM_ORG_ID=
VIAM_LOCATION_ID=

# --- Tailscale (optional) ---
# Leave blank to skip Tailscale installation entirely.
TAILSCALE_AUTH_KEY=

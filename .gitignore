# Operator secrets (never commit)
config/tailscale.key
config/viam-credentials.env
config/*.env
!config/*.env.example
config/environments/
config/ssh_host_key.pub
config/ssh_host_key

# Per-machine credentials (generated at provision time)
http-server/machines/

# Staged secrets (generated by build-config.sh, served by HTTP server)
http-server/config/tailscale.key

# Ubuntu installer binaries (large, downloaded separately)
http-server/ubuntu/vmlinuz
http-server/ubuntu/initrd
http-server/ubuntu/casper/
netboot/vmlinuz
netboot/initrd
netboot/grubx64.efi
netboot/grub/x86_64-efi/

# Generated autoinstall config (contains stamped secrets)
http-server/autoinstall/user-data

# ISOs and Pi base images
*.iso
*.img
*.img.xz

# Python venv
.venv/

# Logs
dnsmasq.log

# OS / editor
.DS_Store
*.swp
*~
.mcp.json
